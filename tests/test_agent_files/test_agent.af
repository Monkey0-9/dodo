              "func_response": "{\n  \"status\": \"OK\",\n  \"message\": \"  1â†’[project]\\n  2â†’name = \\\"dodo\\\"\\n  3â†’version = \\\"0.14.1\\\"\\n  4â†’description = \\\"Create LLM agents with long-term memory and custom tools\\\"\\n  5â†’authors = [\\n  6â†’    {name = \\\"Dodo Team\\\", email = \\\"contact@dodo.com\\\"},\\n  7â†’]\\n  8â†’license = {text = \\\"Apache License\\\"}\\n  9â†’readme = \\\"README.md\\\"\\n 10â†’requires-python = \\\"<3.14,>=3.11\\\"\\n 11â†’dependencies = [\\n 12â†’    \\\"typer>=0.15.2\\\",\\n 13â†’    \\\"questionary>=2.0.1\\\",\\n 14â†’    \\\"pytz>=2023.3.post1\\\",\\n 15â†’    \\\"tqdm>=4.66.1\\\",\\n 16â†’    \\\"black[jupyter]>=24.2.0\\\",\\n 17â†’    \\\"setuptools>=70\\\",\\n 18â†’    \\\"prettytable>=3.9.0\\\",\\n 19â†’    \\\"docstring-parser>=0.16,<0.17\\\",\\n 20â†’    \\\"httpx>=0.28.0\\\",\\n 21â†’    \\\"numpy>=2.1.0\\\",\\n 22â†’    \\\"demjson3>=3.0.6\\\",\\n 23â†’    \\\"pyyaml>=6.0.1\\\",\\n 24â†’    \\\"sqlalchemy-json>=0.7.0\\\",\\n 25â†’    \\\"pydantic>=2.10.6\\\",\\n 26â†’    \\\"html2text>=2020.1.16\\\",\\n 27â†’    \\\"sqlalchemy[asyncio]>=2.0.41\\\",\\n 28â†’    \\\"python-box>=7.1.1\\\",\\n 29â†’    \\\"sqlmodel>=0.0.16\\\",\\n 30â†’    \\\"python-multipart>=0.0.19\\\",\\n 31â†’    \\\"sqlalchemy-utils>=0.41.2\\\",\\n 32â†’    \\\"pydantic-settings>=2.2.1\\\",\\n 33â†’    \\\"httpx-sse>=0.4.0\\\",\\n 34â†’    \\\"nltk>=3.8.1\\\",\\n 35â†’    \\\"alembic>=1.13.3\\\",\\n 36â†’    \\\"pyhumps>=3.8.0\\\",\\n 37â†’    \\\"pathvalidate>=3.2.1\\\",\\n 38â†’    \\\"sentry-sdk[fastapi]==2.19.1\\\",\\n 39â†’    \\\"rich>=13.9.4\\\",\\n 40â†’    \\\"brotli>=1.1.0\\\",\\n 41â†’    \\\"grpcio>=1.68.1\\\",\\n 42â†’    \\\"grpcio-tools>=1.68.1\\\",\\n 43â†’    \\\"llama-index>=0.12.2\\\",\\n 44â†’    \\\"llama-index-embeddings-openai>=0.3.1\\\",\\n 45â†’    \\\"anthropic>=0.75.0\\\",\\n 46â†’    \\\"dodo-client>=1.1.2\\\",\\n 47â†’    \\\"openai>=1.99.9\\\",\\n 48â†’    \\\"opentelemetry-api==1.30.0\\\",\\n 49â†’    \\\"opentelemetry-sdk==1.30.0\\\",\\n 50â†’    \\\"opentelemetry-instrumentation-requests==0.51b0\\\",\\n 51â†’    \\\"opentelemetry-instrumentation-sqlalchemy==0.51b0\\\",\\n 52â†’    \\\"opentelemetry-exporter-otlp==1.30.0\\\",\\n 53â†’    \\\"faker>=36.1.0\\\",\\n 54â†’    \\\"colorama>=0.4.6\\\",\\n 55â†’    \\\"marshmallow-sqlalchemy>=1.4.1\\\",\\n 56â†’    \\\"datamodel-code-generator[http]>=0.25.0\\\",\\n 57â†’    \\\"mcp[cli]>=1.9.4\\\",\\n 58â†’    \\\"exa-py>=1.15.4\\\",\\n 59â†’    \\\"apscheduler>=3.11.0\\\",\\n 60â†’    \\\"aiomultiprocess>=0.9.1\\\",\\n 61â†’    \\\"matplotlib>=3.10.1\\\",\\n 62â†’    \\\"tavily-python>=0.7.2\\\",\\n 63â†’    \\\"temporalio>=1.8.0\\\",\\n 64â†’    \\\"mistralai>=1.8.1\\\",\\n 65â†’    \\\"structlog>=25.4.0\\\",\\n 66â†’    \\\"certifi>=2025.6.15\\\",\\n 67â†’    \\\"markitdown[docx,pdf,pptx]>=0.1.2\\\",\\n 68â†’    \\\"orjson>=3.11.1\\\",\\n 69â†’    \\\"ruff[dev]>=0.12.10\\\",\\n 70â†’    \\\"trafilatura\\\",\\n 71â†’    \\\"readability-lxml\\\",\\n 72â†’    \\\"google-genai>=1.15.0\\\",\\n 73â†’    \\\"datadog>=0.49.1\\\",\\n 74â†’    \\\"psutil>=5.9.0\\\",\\n 75â†’]\\n 76â†’\\n 77â†’[project.scripts]\\n 78â†’dodo = \\\"dodo.main:app\\\"\\n 79â†’\\n 80â†’[project.optional-dependencies]\\n 81â†’# ====== Databases ======\\n 82â†’postgres = [\\n 83â†’    \\\"pgvector>=0.2.3\\\",\\n 84â†’    \\\"pg8000>=1.30.3\\\",\\n 85â†’    \\\"psycopg2-binary>=2.9.10\\\",\\n 86â†’    \\\"psycopg2>=2.9.10\\\",\\n 87â†’    \\\"asyncpg>=0.30.0\\\",\\n 88â†’]\\n 89â†’redis = [\\\"redis>=6.2.0\\\"]\\n 90â†’pinecone = [\\\"pinecone[asyncio]>=7.3.0\\\"]\\n 91â†’sqlite = [\\\"aiosqlite>=0.21.0\\\", \\\"sqlite-vec>=0.1.7a2\\\"]\\n 92â†’\\n 93â†’# ====== Server ======\\n 94â†’experimental = [\\n 95â†’    \\\"uvloop>=0.21.0\\\",\\n 96â†’    \\\"granian[uvloop,reload]>=2.3.2\\\",\\n 97â†’]\\n 98â†’server = [\\n 99â†’    \\\"websockets\\\",\\n100â†’    \\\"fastapi>=0.115.6\\\",\\n101â†’    \\\"uvicorn==0.29.0\\\",\\n102â†’]\\n103â†’\\n104â†’# ====== LLM Providers ======\\n105â†’bedrock = [\\n106â†’    \\\"boto3>=1.36.24\\\",\\n107â†’    \\\"aioboto3>=14.3.0\\\",\\n108â†’]\\n109â†’\\n110â†’# ====== Development ======\\n111â†’dev = [\\n112â†’    \\\"pytest\\\",\\n113â†’    \\\"pytest-asyncio>=0.24.0\\\",\\n114â†’    \\\"pytest-order>=1.2.0\\\",\\n115â†’    \\\"pytest-mock>=3.14.0\\\",\\n116â†’    \\\"pytest-json-report>=1.5.0\\\",\\n117â†’    \\\"pexpect>=4.9.0\\\",\\n118â†’    \\\"pre-commit>=3.5.0\\\",\\n119â†’    \\\"pyright>=1.1.347\\\",\\n120â†’    \\\"ipykernel>=6.29.5\\\",\\n121â†’    \\\"ipdb>=0.13.13\\\",\\n122â†’]\\n123â†’\\n124â†’# ====== Other ======\\n125â†’cloud-tool-sandbox = [\\\"e2b-code-interpreter>=1.0.3\\\"]  # TODO: make this more explicitly e2b\\n126â†’modal = [\\\"modal>=1.1.0\\\"]\\n127â†’external-tools = [\\n128â†’    \\\"docker>=7.1.0\\\",\\n129â†’    \\\"langchain>=0.3.7\\\",\\n130â†’    \\\"wikipedia>=1.4.0\\\",\\n131â†’    \\\"langchain-community>=0.3.7\\\",\\n132â†’    \\\"exa-py>=1.15.4\\\",\\n133â†’    \\\"turbopuffer>=0.5.17\\\",\\n134â†’]\\n135â†’desktop = [\\n136â†’    \\\"websockets\\\",\\n137â†’    \\\"fastapi>=0.115.6\\\",\\n138â†’    \\\"uvicorn==0.29.0\\\",\\n139â†’    \\\"docker>=7.1.0\\\",\\n140â†’    \\\"langchain>=0.3.7\\\",\\n141â†’    \\\"wikipedia>=1.4.0\\\",\\n142â†’    \\\"langchain-community>=0.3.7\\\",\\n143â†’    \\\"locust>=2.31.5\\\",\\n144â†’    \\\"aiosqlite>=0.21.0\\\",\\n145â†’    \\\"sqlite-vec>=0.1.7a2\\\",\\n146â†’    \\\"pgvector>=0.2.3\\\",\\n147â†’    \\\"tiktoken>=0.11.0\\\",\\n148â†’    \\\"async-lru>=2.0.5\\\",\\n149â†’    \\\"magika>=0.6.2\\\",\\n150â†’    #\\\"pgserver>=0.1.4\\\",\\n151â†’]\\n152â†’profiling = [\\n153â†’    \\\"ddtrace>=2.18.2\\\",\\n154â†’]\\n155â†’\\n156â†’[build-system]\\n157â†’requires = [\\\"hatchling\\\"]\\n158â†’build-backend = \\\"hatchling.build\\\"\\n159â†’\\n160â†’[tool.hatch.build.targets.wheel]\\n161â†’packages = [\\\"dodo\\\"]\\n162â†’\\n163â†’\\n164â†’[tool.ruff]\\n165â†’line-length = 140\\n166â†’target-version = \\\"py312\\\"\\n167â†’extend-exclude = [\\n168â†’    \\\"examples/*\\\",\\n169â†’    \\\"tests/data/*\\\",\\n170â†’]\\n171â†’\\n172â†’[tool.ruff.lint]\\n173â†’select = [\\n174â†’    \\\"E\\\",   # pycodestyle errors\\n175â†’    \\\"W\\\",   # pycodestyle warnings\\n176â†’    \\\"F\\\",   # pyflakes\\n177â†’    \\\"I\\\",   # isort\\n178â†’]\\n179â†’ignore = [\\n180â†’    \\\"E501\\\",  # line too long (handled by formatter)\\n181â†’    \\\"E402\\\",  # module import not at top of file\\n182â†’    \\\"E711\\\",  # none-comparison\\n183â†’    \\\"E712\\\",  # true-false-comparison\\n184â†’    \\\"E722\\\",  # bare except\\n185â†’    \\\"E721\\\",  # type comparison\\n186â†’    \\\"F401\\\",  # unused import\\n187â†’    \\\"F821\\\",  # undefined name\\n188â†’    \\\"F811\\\",  # redefined while unused\\n189â†’    \\\"F841\\\",  # local variable assigned but never used\\n190â†’    \\\"W293\\\",  # blank line contains whitespace\\n191â†’]\\n192â†’\\n193â†’[tool.ruff.lint.isort]\\n194â†’force-single-line = false\\n195â†’combine-as-imports = true\\n196â†’split-on-trailing-comma = true\\n197â†’\\n198â†’[tool.ruff.format]\\n199â†’quote-style = \\\"double\\\"\\n200â†’indent-style = \\\"space\\\"\\n201â†’skip-magic-trailing-comma = false\\n202â†’line-ending = \\\"auto\\\"\\n203â†’\\n204â†’[tool.pytest.ini_options]\\n205â†’asyncio_mode = \\\"auto\\\"\\n206â†’\",\n  \"time\": \"2025-11-29 02:52:25 AM UTC+0000\"\n}"
