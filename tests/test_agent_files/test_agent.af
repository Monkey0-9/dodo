              "minItems": 1,
              "description": "Array of edit operations to perform sequentially on the file"
            }
          },
          "required": [
            "file_path",
            "edits"
          ],
          "additionalProperties": false,
          "$schema": "http://json-schema.org/draft-07/schema#"
        }
      },
      "args_json_schema": null,
